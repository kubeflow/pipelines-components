# Example Containerfile for KFP Component Base Image
#
# This demonstrates best practices for creating custom base images
# for Kubeflow Pipelines components.
#
# The resulting image will be pushed to:
#   ghcr.io/kubeflow/pipelines-components-example:main
#
# Usage in a component:
#   @dsl.component(base_image="ghcr.io/kubeflow/pipelines-components-example:main")
#   def my_component():
#       import pandas as pd
#       ...

FROM python:3.11-slim

LABEL org.opencontainers.image.title="KFP Component Base Image: <Your-Image-name>"
LABEL org.opencontainers.image.description="Example base image with common ML dependencies for Kubeflow Pipelines components"
LABEL org.opencontainers.image.source="https://github.com/kubeflow/pipelines-components"
LABEL org.opencontainers.image.licenses="Apache-2.0"
LABEL maintainer="Kubeflow Pipelines"

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir \
        numpy==1.26.4 \
        pandas==2.2.0 \
        scikit-learn==1.4.0

WORKDIR /app

# Optional: create a non-root user and switch to it for running components.
# This provides added security in many Kubernetes environments, but can make the image
# not work out of the box on platforms like OpenShift that run containers with arbitrary UIDs.
#
# If you need OpenShift compatibility, consider using the alternative (commented) block below
# that grants group 0 access. Other distributions may have different requirements. Please verify
# what’s appropriate for your environment.
RUN groupadd --system kfp && \
    useradd --system --gid kfp --create-home --home-dir /home/kfp kfp && \
    chown -R kfp:kfp /app

USER kfp

# OpenShift-friendly alternative (example):
# - Keep the non-root setup, but make key directories writable by group 0 so a random UID can run.
# RUN groupadd --system kfp && \
#     useradd --system --gid kfp --create-home --home-dir /home/kfp kfp && \
#     chgrp -R 0 /app /home/kfp && \
#     chmod -R g=u /app /home/kfp
